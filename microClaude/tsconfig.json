{
  "compilerOptions": {
    "target": "ES2023",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "src/*": [
        "./src/*"
      ],
      "vendor/*": [
        "./vendor/*"
      ]
    },
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "ignoreDeprecations": "6.0",
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true,
    "types": [
      "bun-types",
      "node",
      "react"
    ]
  },
  "include": [
    "global.d.ts",
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "vendor/**/*.ts",
    "vendor/**/*.tsx",
    "scripts/**/*.mjs",
    "stubs/**/*.d.ts"
  ]
}
